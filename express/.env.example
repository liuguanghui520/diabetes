NODE_ENV=development
HOST=127.0.0.1
PORT=3001
UPLOAD_PUBLIC_BASE_URL=http://127.0.0.1:3001
UPLOAD_STORAGE_DIR=

JWT_SECRET=change-this-in-production
JWT_EXPIRES_IN=7d

CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=600
SENSITIVE_RATE_LIMIT_WINDOW_MS=600000
SENSITIVE_RATE_LIMIT_MAX=30

KINGBASE_HOST=127.0.0.1
KINGBASE_PORT=54321
KINGBASE_DATABASE=diabetes_assistant
KINGBASE_USER=system
KINGBASE_PASSWORD=replace-with-your-db-password
KINGBASE_SSL=false
DB_CONNECT_ON_START=false

# SSH 隧道配置（远程库仅监听服务器本机时启用）
SSH_ENABLED=false
SSH_HOST=your-server-host
SSH_PORT=22
SSH_USER=root
SSH_PASSWORD=replace-with-your-ssh-password
SSH_REMOTE_DB_HOST=127.0.0.1
SSH_REMOTE_DB_PORT=54321
SSH_LOCAL_PORT=15432

DIFY_BASE_URL=http://127.0.0.1
DIFY_RISK_API_KEY=app-xxx
DIFY_PLAN_API_KEY=app-xxx
DIFY_CHECKIN_API_KEY=app-xxx
DIFY_REPORT_API_KEY=app-xxx
DIFY_ASSISTANT_API_KEY=app-xxx
DIFY_DOCTOR_API_KEY=app-xxx
DIFY_ADMIN_API_KEY=app-xxx
DIFY_TIMEOUT_MS=120000

INTERNAL_DIFY_TOKEN=generate-a-strong-random-token
