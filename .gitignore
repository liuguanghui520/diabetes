# Keep the repository root clean for staged subprojects.
*
!/.gitignore
!/README.md
!/frontend/
!/frontend/**
!/frontend/.env.example
!/express/
!/express/**

express/node_modules/
express/.env
express/.env.*
!express/.env.example
express/coverage/
express/dist/
express/docs/
docs/

frontend/node_modules/
frontend/dist/
frontend/.env
frontend/.env.*
!frontend/.env.example
